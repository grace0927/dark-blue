{
  "name": "dark-blue",
  "version": "0.3.1",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles": "./dist/index.css",
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "rm -rf dist && vite build --mode library && tsc -p tsconfig.lib.json",
    "release": "pnpm build:lib && changeset publish",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/addon-links": "10.4.4",
    "@storybook/addon-onboarding": "10.4.4",
    "@storybook/blocks": "^8.6.18",
    "@storybook/react": "10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@storybook/test": "8.6.15",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "10.4.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  },
  "overrides": {
    "eslint": "$eslint"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/grace0927/dark-blue.git"
  },
  "packageManager": "pnpm@10.4.1"
}
